#!/usr/bin/env bash
set -euo pipefail

preview_pane() {
  local pane_id="$1"
  tmux display-message -p -t "$pane_id" '#[bold]#S:#{window_index} #{window_name}.#{pane_index}#[default] • #{pane_current_command} • #{pane_current_path}'
  printf '\n'
  tmux capture-pane -p -t "$pane_id" -S -80
}

if [[ "${1:-}" == "--preview" ]]; then
  preview_pane "$2"
  exit 0
fi

SCRIPT_PATH="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)/$(basename -- "${BASH_SOURCE[0]}")"
SEP='::TMUX::'

panes="$({
  tmux list-panes -s -F "#{pane_id}${SEP}#{window_index}${SEP}#{window_name}${SEP}#{pane_index}${SEP}#{?pane_active,*, }${SEP}#{pane_current_command}${SEP}#{pane_current_path}" |
    awk -F "$SEP" 'BEGIN { OFS="\t" } { print $1, $3, $6 }'
} | fzf \
  --delimiter=$'\t' \
  --with-nth=2.. \
  --layout=reverse \
  --border \
  --prompt='pane > ' \
  --header=$'enter jump • esc cancel' \
  --preview-window='right,60%,border-left' \
  --preview "$SCRIPT_PATH --preview {1}")"

[[ -n "$panes" ]] || exit 0
pane_id="${panes%%$'\t'*}"
tmux select-window -t "$pane_id"
tmux select-pane -t "$pane_id"
